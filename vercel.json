{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/(.*)", "destination": "/" }
  ],
  "cleanUrls": true,
  "crons": [
    { "path": "/api/sync-icloud", "schedule": "0 0 * * *" },
    { "path": "/api/daily-report", "schedule": "0 7 * * *" }
  ]
}
