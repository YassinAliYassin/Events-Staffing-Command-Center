# Firebase Configuration (required for Firestore database)
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=freshchat-3545e.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=freshchat-3545e
VITE_FIREBASE_STORAGE_BUCKET=freshchat-3545e.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Google Calendar API (Service Account)
# 1. Go to https://console.cloud.google.com/
# 2. Create new project -> Enable Google Calendar API
# 3. Create Service Account -> Generate JSON key
# 4. Share your Google Calendar with the service account email
# 5. Encode the JSON key to base64: base64 service-account.json
GOOGLE_SERVICE_ACCOUNT_BASE64=

# Gemini API Key for AI features
# Get from: https://aistudio.google.com/
VITE_GEMINI_API_KEY=

# Vercel Deployment
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=